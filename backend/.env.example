# Copy to .env and fill in for production use. Read directly by the binary
# (`go run`/`./server`) and by `docker compose` (via the `env_file` entry in
# docker-compose.yml) — same file, both paths. All values have dev-safe
# defaults so the server also runs with none of this set.

PORT=8080
DB_PATH=data/cloudcost.db

# Change these before exposing the server beyond localhost.
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-to-a-long-random-string

# First-boot admin account (only used if no users exist yet).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# How often (minutes) to pull fresh costs from AWS/Azure/GCP/OCI.
SYNC_INTERVAL_MINUTES=60
